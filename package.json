{
  "name": "screensense-ai",
  "version": "1.0.2",
  "description": "AI-powered screen overlay for captions and scene analysis",
  "author": "chanikya07 <bellamchanikya@gmail.com>",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:mac:x64": "electron-builder --mac dmg --x64",
    "build:mac:arm64": "electron-builder --mac dmg --arm64",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.yourname.screensense",
    "productName": "ScreenSense AI",
    "directories": {
      "output": "dist"
    },
    "artifactName": "ScreenSense-AI-Setup-${version}.${ext}",
    "files": [
      "src/**/*",
      "assets/**/*",
      "local_whisper_server.py",
      "requirements-local-whisper.txt",
      "start-local-whisper.bat",
      "start-local-whisper.sh",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      },
      {
        "from": "local_whisper_server.py",
        "to": "local_whisper_server.py"
      },
      {
        "from": "requirements-local-whisper.txt",
        "to": "requirements-local-whisper.txt"
      },
      {
        "from": "start-local-whisper.bat",
        "to": "start-local-whisper.bat"
      },
      {
        "from": "start-local-whisper.sh",
        "to": "start-local-whisper.sh"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "artifactName": "ScreenSense-AI-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "chanikya07 <bellamchanikya@gmail.com>",
      "artifactName": "ScreenSense-AI-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^25.0.0"
  }
}
