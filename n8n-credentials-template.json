{
  "credentials": [
    {
      "name": "AWS Bedrock Credentials",
      "type": "aws",
      "data": {
        "accessKeyId": "YOUR_AWS_ACCESS_KEY_ID",
        "secretAccessKey": "YOUR_AWS_SECRET_ACCESS_KEY",
        "region": "us-east-1"
      }
    },
    {
      "name": "Screen Sense Rotation Auth",
      "type": "httpHeaderAuth",
      "data": {
        "credentials": {
          "generic": [
            {
              "key": "x-rotation-secret",
              "value": "YOUR_KEY_ROTATION_SECRET"
            }
          ]
        }
      }
    },
    {
      "name": "Key Vault Bearer Token",
      "type": "httpHeaderAuth",
      "data": {
        "credentials": {
          "generic": [
            {
              "key": "Authorization",
              "value": "Bearer YOUR_KEY_VAULT_TOKEN"
            }
          ]
        }
      }
    }
  ],
  "environment": {
    "AWS_REGION": "us-east-1",
    "AWS_ACCESS_KEY_ID": "YOUR_AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY": "YOUR_AWS_SECRET_ACCESS_KEY",
    "KEY_ROTATION_SECRET": "YOUR_KEY_ROTATION_SECRET",
    "KEY_ROTATION_ENDPOINT": "http://127.0.0.1:8765/rotate-keys",
    "KEY_VAULT_ENDPOINT": "https://your-key-vault.example.com/api/keys",
    "KEY_VAULT_TOKEN": "YOUR_KEY_VAULT_TOKEN",
    "SCREEN_SENSE_ROTATION_URL": "http://127.0.0.1:8765",
    "BEDROCK_REGION": "us-east-1",
    "BEDROCK_MODEL_ID": "anthropic.claude-3-sonnet-20240229-v1:0"
  }
}
